# Root / shared example. Copy to .env or into each app as needed.
# Each app (gateway, policy-service, etc.) has its own .env.example with the vars it needs.

# OpenRouter (used by policy-service, validation-service, scoring-service, data-extraction-pipe, extract-file)
OPENROUTER_API_KEY=sk-or-your-key-here
OPENROUTER_MODEL=anthropic/claude-sonnet-4

# Pinecone (policy-service only – vector DB for policy criteria)
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_INDEX_NAME_POLICIES=claim-shield-policies

# Service URLs (gateway uses these to call other services)
EXTRACT_FILE_SERVICE_URL=http://localhost:8080
MAPPING_SERVICE_URL=http://localhost:8002
VALIDATION_SERVICE_URL=http://localhost:8003
SCORING_SERVICE_URL=http://localhost:8004
POLICY_SERVICE_URL=http://localhost:8005
