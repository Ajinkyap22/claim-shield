# OpenRouter (single LLM provider for all services)
OPENROUTER_API_KEY=sk-or-your-key-here
OPENROUTER_MODEL=anthropic/claude-sonnet-4

# Pinecone (vector database for policy storage + embeddings)
PINECONE_API_KEY=pc-your-key-here
PINECONE_INDEX_NAME=claim-shield-policies

# Service URLs (for gateway → service communication)
EXTRACT_FILE_SERVICE_URL=http://localhost:8080
MAPPING_SERVICE_URL=http://localhost:8002
VALIDATION_SERVICE_URL=http://localhost:8003
SCORING_SERVICE_URL=http://localhost:8004
POLICY_SERVICE_URL=http://localhost:8005
