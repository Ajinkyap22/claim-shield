# Policy service – default port 8005
PORT=8005

# OpenRouter (LLM for policy criteria extraction)
# https://openrouter.ai/settings/keys
OPENROUTER_API_KEY=sk-or-your-key-here
OPENROUTER_MODEL=anthropic/claude-haiku-4.5

# Pinecone (vector store for policy criteria)
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_INDEX_NAME_POLICIES=claim-shield-policies

# Optional: chunking and concurrency
# CHUNK_BATCH_SIZE=5
# MAX_CONCURRENT_BATCHES=5
